{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kui-realtime",
  "main": "src/index.js",
  "compatibility_date": "2026-07-12",
  "workers_dev": true,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "k-ui0715",
      "database_id": "4ec2fd9b-89e0-4826-91da-ebe524d82e3d"
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "VPS_PRESENCE", "class_name": "VpsPresence" },
      { "name": "DASHBOARD_HUB", "class_name": "DashboardHub" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["VpsPresence", "DashboardHub"]
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  }
}
